{
  "_comment": [
    "==========================================================================",
    " DX-Engine — Metadata Bridge JSON Schema (Admission Case Type example)",
    " This is the exact payload generated by AdmissionDX::getFlow() and",
    " returned to the JS interpreter on a GET ?dx=admission_case request.",
    "==========================================================================",

    "Envelope keys (injected by DXController::wrapFlow):",
    "  _dx_version  – Framework version string",
    "  _status      – Always 'ok' on a successful GET",
    "  _timestamp   – ISO-8601 server timestamp",

    "Flow keys:",
    "  dx_id         – Unique identifier; matches Router registration key",
    "  title         – Top-level form heading",
    "  description   – Shown only on step 1 as a subtitle",
    "  version       – Business-logic version for auditing",
    "  post_endpoint – URL the JS POSTs every step payload to",
    "  initial_state – Flat key→value map; pre-populates all fields",
    "  context       – Opaque server data merged into every POST body",
    "  steps         – Ordered array of StepDescriptor objects",

    "StepDescriptor keys:",
    "  step_id      – Snake-case identifier; echoed back in _step POST field",
    "  title        – Step label shown in the Stepper bar",
    "  submit_label – Text for the primary action button",
    "  cancel_label – Text for the back button (null hides it)",
    "  is_final     – true on the last step; signals a 'save' action",
    "  components   – Ordered array of ComponentDescriptor objects",

    "ComponentDescriptor keys:",
    "  component_type    – Registry key (see Component Registry table below)",
    "  field_key         – DOM name attribute; POST body key; state key",
    "  label             – Human-readable field label",
    "  placeholder       – Input placeholder text",
    "  required          – Drives both FE and BE validation",
    "  readonly          – Renders as disabled input",
    "  value             – Pre-filled value from initial_state",
    "  options           – [{ value, label, css_class? }] for select/radio/checkbox_group",
    "  validation_rules  – { min, max, pattern (JS RegExp string), message }",
    "  visibility_rule   – { field, operator, value } — show/hide this component",
    "  col_span          – Bootstrap grid columns (1–12); maps to col-md-N",
    "  css_class         – Extra Bootstrap/custom classes added to the input",
    "  help_text         – Small hint rendered below the input",
    "  attrs             – Arbitrary HTML attributes merged onto the input element",

    "Supported component_type values (built-in registry):",
    "  text_input, email_input, number_input, date_input,",
    "  textarea, select, radio, checkbox_group, file_upload,",
    "  heading, paragraph, divider, alert, hidden",

    "Supported visibility_rule operators:",
    "  eq, neq, gt, lt, gte, lte, in, nin, empty, not_empty"
  ],

  "_dx_version": "1.0",
  "_status": "ok",
  "_timestamp": "2024-01-15T10:30:00+00:00",

  "dx_id": "admission_case",
  "title": "Patient Admission",
  "description": "Register a new patient admission in two steps.",
  "version": "1.0",
  "post_endpoint": "/dx-engine/public/api/dx.php?dx=admission_case",
  "initial_state": {},
  "context": {
    "admission_id": 0
  },

  "steps": [

    {
      "_comment": "──────────────────── STEP 1: Patient Information ──────────────────────",
      "step_id"     : "patient_info",
      "title"       : "Patient Information",
      "submit_label": "Next: Clinical Data",
      "cancel_label": null,
      "is_final"    : false,
      "components"  : [

        {
          "_comment"      : "Non-interactive section heading (col_span=12 spans full width)",
          "component_type": "heading",
          "field_key"     : null,
          "label"         : "Personal Details",
          "col_span"      : 12
        },

        {
          "_comment"        : "First Name — 6-col (half width); regex enforces letters/spaces/hyphens/apostrophes",
          "component_type"  : "text_input",
          "field_key"       : "first_name",
          "label"           : "First Name",
          "placeholder"     : "Enter first name",
          "required"        : true,
          "readonly"        : false,
          "value"           : "",
          "col_span"        : 6,
          "css_class"       : "",
          "help_text"       : "",
          "attrs"           : {},
          "options"         : [],
          "visibility_rule" : null,
          "validation_rules": {
            "min"    : 2,
            "max"    : 80,
            "pattern": "^[a-zA-Z\\s\\-']+$",
            "message": "First name may only contain letters, spaces, hyphens or apostrophes."
          }
        },

        {
          "component_type"  : "text_input",
          "field_key"       : "last_name",
          "label"           : "Last Name",
          "placeholder"     : "Enter last name",
          "required"        : true,
          "readonly"        : false,
          "value"           : "",
          "col_span"        : 6,
          "attrs"           : {},
          "validation_rules": {
            "min"    : 2,
            "max"    : 80,
            "pattern": "^[a-zA-Z\\s\\-']+$",
            "message": "Last name may only contain letters, spaces, hyphens or apostrophes."
          }
        },

        {
          "_comment"        : "date_input maps to <input type=date>; attrs.max prevents future DOB",
          "component_type"  : "date_input",
          "field_key"       : "date_of_birth",
          "label"           : "Date of Birth",
          "required"        : true,
          "value"           : "",
          "col_span"        : 6,
          "attrs"           : { "max": "2024-01-15" },
          "validation_rules": {}
        },

        {
          "_comment"        : "select renders as <select class=form-select>; options from static array",
          "component_type"  : "select",
          "field_key"       : "gender",
          "label"           : "Gender",
          "required"        : true,
          "value"           : "",
          "col_span"        : 6,
          "options"         : [
            { "value": "",           "label": "— Select —" },
            { "value": "male",       "label": "Male" },
            { "value": "female",     "label": "Female" },
            { "value": "other",      "label": "Other" },
            { "value": "prefer_not", "label": "Prefer not to say" }
          ],
          "validation_rules": {}
        },

        { "component_type": "divider", "col_span": 12 },

        {
          "component_type": "heading",
          "label"         : "Contact Information",
          "col_span"      : 12
        },

        {
          "_comment"        : "Phone field — pattern mirrors PHP PatientModel rule",
          "component_type"  : "text_input",
          "field_key"       : "contact_phone",
          "label"           : "Phone Number",
          "placeholder"     : "+1 (555) 000-0000",
          "required"        : true,
          "value"           : "",
          "col_span"        : 6,
          "validation_rules": {
            "pattern": "^[0-9+\\-()\\s]{7,20}$",
            "message": "Enter a valid phone number."
          }
        },

        {
          "_comment"        : "email_input — component_type triggers built-in RFC-lite e-mail check in Validator",
          "component_type"  : "email_input",
          "field_key"       : "contact_email",
          "label"           : "Email Address",
          "placeholder"     : "patient@example.com",
          "required"        : false,
          "value"           : "",
          "col_span"        : 6,
          "validation_rules": {
            "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$",
            "message": "Enter a valid email address."
          }
        },

        {
          "_comment"        : "textarea — attrs.rows controls visible height",
          "component_type"  : "textarea",
          "field_key"       : "address",
          "label"           : "Home Address",
          "placeholder"     : "Street, City, State, ZIP",
          "required"        : false,
          "value"           : "",
          "col_span"        : 12,
          "attrs"           : { "rows": 3 },
          "validation_rules": { "max": 500 }
        }

      ]
    },

    {
      "_comment": "──────────────────── STEP 2: Clinical Data ────────────────────────────",
      "step_id"     : "clinical_data",
      "title"       : "Clinical Data",
      "submit_label": "Complete Admission",
      "cancel_label": "Back: Patient Info",
      "is_final"    : true,
      "components"  : [

        {
          "component_type": "heading",
          "label"         : "Triage & Admission Details",
          "col_span"      : 12
        },

        {
          "_comment"  : "radio — each option carries css_class which adds the triage colour dot via CSS",
          "component_type": "radio",
          "field_key" : "triage_level",
          "label"     : "Triage Level",
          "required"  : true,
          "value"     : "",
          "col_span"  : 12,
          "options"   : [
            { "value": "1", "label": "Level 1 — Immediate (Resuscitation)", "css_class": "triage-1" },
            { "value": "2", "label": "Level 2 — Emergent",                  "css_class": "triage-2" },
            { "value": "3", "label": "Level 3 — Urgent",                    "css_class": "triage-3" },
            { "value": "4", "label": "Level 4 — Less Urgent",               "css_class": "triage-4" },
            { "value": "5", "label": "Level 5 — Non-Urgent",                "css_class": "triage-5" }
          ]
        },

        {
          "_comment"  : "options array populated live from DepartmentModel in preProcess()",
          "component_type": "select",
          "field_key" : "department_id",
          "label"     : "Admitting Department",
          "required"  : true,
          "value"     : "",
          "col_span"  : 6,
          "options"   : [
            { "value": "",  "label": "— Select Department —" },
            { "value": "1", "label": "Emergency Department" },
            { "value": "2", "label": "Intensive Care Unit" },
            { "value": "3", "label": "Orthopaedics" },
            { "value": "4", "label": "Cardiology" },
            { "value": "5", "label": "Neurology" }
          ]
        },

        {
          "component_type"  : "text_input",
          "field_key"       : "attending_physician",
          "label"           : "Attending Physician",
          "placeholder"     : "Dr. Full Name",
          "required"        : false,
          "value"           : "",
          "col_span"        : 6,
          "validation_rules": { "max": 120 }
        },

        {
          "component_type"  : "textarea",
          "field_key"       : "chief_complaint",
          "label"           : "Chief Complaint",
          "placeholder"     : "Describe the primary reason for admission\u2026",
          "required"        : true,
          "value"           : "",
          "col_span"        : 12,
          "attrs"           : { "rows": 3 },
          "validation_rules": { "min": 3, "max": 255 }
        },

        {
          "component_type"  : "textarea",
          "field_key"       : "notes",
          "label"           : "Clinical Notes",
          "placeholder"     : "Additional observations\u2026",
          "required"        : false,
          "value"           : "",
          "col_span"        : 12,
          "attrs"           : { "rows": 4 },
          "validation_rules": {}
        },

        { "component_type": "divider", "col_span": 12 },

        {
          "_comment"  : "This select controls a visibility_rule for the insurance block below",
          "component_type": "select",
          "field_key" : "has_insurance",
          "label"     : "Insurance Coverage",
          "required"  : true,
          "value"     : "0",
          "col_span"  : 12,
          "options"   : [
            { "value": "0", "label": "No Insurance / Self-Pay" },
            { "value": "1", "label": "Has Insurance" }
          ]
        },

        {
          "_comment"        : "Heading only shown when has_insurance === '1'",
          "component_type"  : "heading",
          "label"           : "Insurance Details",
          "col_span"        : 12,
          "visibility_rule" : { "field": "has_insurance", "operator": "eq", "value": "1" }
        },

        {
          "_comment"        : "visibility_rule: show only when has_insurance eq '1'",
          "component_type"  : "text_input",
          "field_key"       : "provider_name",
          "label"           : "Insurance Provider",
          "placeholder"     : "e.g. Blue Cross Blue Shield",
          "required"        : false,
          "value"           : "",
          "col_span"        : 6,
          "visibility_rule" : { "field": "has_insurance", "operator": "eq", "value": "1" },
          "validation_rules": { "max": 120 }
        },

        {
          "component_type"  : "text_input",
          "field_key"       : "policy_number",
          "label"           : "Policy Number",
          "placeholder"     : "Policy #",
          "required"        : false,
          "value"           : "",
          "col_span"        : 6,
          "visibility_rule" : { "field": "has_insurance", "operator": "eq", "value": "1" },
          "validation_rules": { "max": 60 }
        },

        {
          "component_type"  : "text_input",
          "field_key"       : "group_number",
          "label"           : "Group Number",
          "placeholder"     : "Group #",
          "required"        : false,
          "value"           : "",
          "col_span"        : 6,
          "visibility_rule" : { "field": "has_insurance", "operator": "eq", "value": "1" },
          "validation_rules": { "max": 60 }
        },

        {
          "component_type"  : "text_input",
          "field_key"       : "holder_name",
          "label"           : "Policy Holder Name",
          "placeholder"     : "Full name on policy",
          "required"        : false,
          "value"           : "",
          "col_span"        : 6,
          "visibility_rule" : { "field": "has_insurance", "operator": "eq", "value": "1" },
          "validation_rules": { "max": 120 }
        },

        {
          "component_type" : "date_input",
          "field_key"      : "holder_dob",
          "label"          : "Holder Date of Birth",
          "required"       : false,
          "value"          : "",
          "col_span"       : 6,
          "visibility_rule": { "field": "has_insurance", "operator": "eq", "value": "1" }
        },

        {
          "component_type" : "date_input",
          "field_key"      : "expiry_date",
          "label"          : "Policy Expiry Date",
          "required"       : false,
          "value"          : "",
          "col_span"       : 6,
          "visibility_rule": { "field": "has_insurance", "operator": "eq", "value": "1" }
        }

      ]
    }

  ],

  "_schema_reference": {
    "_comment": "POST body sent by the interpreter on each step submit",
    "step_1_post_example": {
      "_step"         : "patient_info",
      "_dx_id"        : "admission_case",
      "_csrf"         : "abc123token",
      "first_name"    : "Jane",
      "last_name"     : "Doe",
      "date_of_birth" : "1990-06-15",
      "gender"        : "female",
      "contact_phone" : "+1 555-234-5678",
      "contact_email" : "jane.doe@example.com",
      "address"       : "123 Main St, Springfield, IL 62701"
    },
    "step_1_success_response": {
      "status"   : "success",
      "message"  : "Patient information saved.",
      "data"     : { "patient_id": 42 },
      "errors"   : [],
      "next_step": "clinical_data"
    },
    "step_1_validation_error_response": {
      "status"   : "validation_error",
      "message"  : "Please correct the highlighted fields.",
      "data"     : null,
      "errors"   : {
        "first_name"    : "First Name is required.",
        "contact_phone" : "Contact Phone must be a valid phone number."
      },
      "next_step": null
    },
    "step_2_post_example": {
      "_step"              : "clinical_data",
      "_dx_id"             : "admission_case",
      "_csrf"              : "abc123token",
      "patient_id"         : 42,
      "admission_id"       : 0,
      "triage_level"       : "2",
      "department_id"      : "1",
      "attending_physician": "Dr. Alice Thompson",
      "chief_complaint"    : "Chest pain, shortness of breath",
      "notes"              : "Patient reports symptoms since 2 hours ago.",
      "has_insurance"      : "1",
      "provider_name"      : "Blue Cross Blue Shield",
      "policy_number"      : "BCBS-00123456",
      "group_number"       : "GRP-789",
      "holder_name"        : "Jane Doe",
      "holder_dob"         : "1990-06-15",
      "expiry_date"        : "2025-12-31"
    },
    "step_2_success_response": {
      "status"   : "success",
      "message"  : "Patient admission completed successfully.",
      "data"     : { "admission_id": 15 },
      "errors"   : [],
      "next_step": null
    }
  }
}
